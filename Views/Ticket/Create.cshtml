@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AdeTeniola - Submit a Complaint</title>
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">

</head>

<body>
    <div class="main-container">
        <div class="branding-section">
            <div class="logo-wrapper">
                <img src="../images/logo.png" alt="AdeTenny Logo" class="brand-logo">
                <h1 class="brand-name">AdeTenny</h1>
            </div>
        </div>

        <div class="form-section">
            
            <form class="complaint-form" method="post" asp-controller="Ticket" asp-action="Create">
                <h2 class="form-title">Complaint</h2>

                <div class="form-group">
                    <input type="text" placeholder="Name" name="FullName" required>
                </div>

                <div class="form-group">
                    <input type="text" placeholder="Account Number" name="AccountNumber" required>
                </div>

                <div class="form-group">
                    <input type="text" placeholder="Title" name="Title">
                </div>

                <div class="form-row">
                    <div class="form-group half">
                        <select name = "Category" required>
                            <option value="" disabled selected>Complaint Category</option>
                            <option value="billing">Billing</option>
                            <option value="technical">Technical Issue</option>
                            <option value="account">Account Access</option>
                            <option value="ATM Issue">ATM Issue</option>
                            <option value="Login Problem">Login Problem</option>
                            <option value="Fraud Complaint">Fraud Complaint</option>
                            <option value="Card Issue">Card Issue</option>
                            <option value="Account Issue">Account Issue</option>
                        </select>
                    </div>
                    <div class="form-group half">
                        <input type="tel" name="PhoneNumber" placeholder="Phone Number">
                    </div>
                </div>

                <div class="form-group">
                    <textarea name="Description" placeholder="Complaint" rows="5" required></textarea>
                </div>

                <button type="submit" class="submit-btn">SUBMIT</button>
            </form>
        </div>
    </div>
</body>
<
</html>

