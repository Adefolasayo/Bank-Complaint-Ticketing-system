@{
    var userRole = Context.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="en">


    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Ticketing_system</title>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link href='https://fonts.googleapis.com/css?family=Laila' rel='stylesheet'>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Ticketing_system.styles.css" asp-append-version="true" />
    <script src="~/js/StaffDashboard.js" asp-append-version="true"></script>
    </head>

    
    <body>
        <div class="dashboard-container">
            <nav class="sidebar">
                <div class="sidebar-header">
                    <img src="/images/logo.png" alt="Logo" class="sidebar-logo">
                    <span class="brand-name">AdeTenny</span>
                </div>

                <ul class="nav-links">
                    @if (userRole == "Agent")
                    {
                        <li>
                            <a asp-controller="Ticket" asp-action="Index" class="@(ViewData["Active"] == "Tickets" ? "active" : "")">
                            <span class="material-symbols-outlined">confirmation_number</span> All Tickets
                            </a>
                        </li>
                    }
                    <li>
                    <a asp-controller="Analytics" asp-action="Index" class="@(ViewData["Active"] == "Analytics" ? "active" : "")">
                        <span class="material-symbols-outlined">analytics</span> Analytics
                        </a>
                    </li>
                     <li>
                    <a asp-controller="Ticket" asp-action="DepartmentTickets" class="@(ViewData["Active"] == "Department Tickets" ? "active" : "")">
                        <span class="material-symbols-outlined">confirmation_number</span> Department Tickets
                        </a>
                    </li> 
                    <li>
                    <a asp-controller="Ticket" asp-action="StaffDashboard" class="@(ViewData["Active"] == "Staff Dashboard" ? "active" : "")">
                        <span class="material-symbols-outlined"> dashboard </span> Staff Dashboard
                        </a>
                    </li>

                
                </ul>

                <div class="sidebar-footer">
                     <a asp-controller="Account" asp-action="Logout"><span class="material-symbols-outlined">logout</span>Logout</a>
                </div>

            
            </nav>

            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    </body>
    

    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</html>
